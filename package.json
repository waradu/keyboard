{
  "name": "@waradu/keyboard",
  "version": "8.0.0",
  "description": "Keyboard manager",
  "keywords": [
    "events",
    "keybinds",
    "keyboard"
  ],
  "homepage": "https://waradu.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/waradu/keyboard.git"
  },
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./nuxt": "./src/nuxt/index.ts"
  },
  "scripts": {
    "playground": "cd playground && bun dev",
    "playground:prepare": "cd playground && bun i",
    "setup": "lefthook install",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix --fix-suggestions",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.3",
    "@nuxt/kit": "4.4.8",
    "@nuxt/schema": "4.4.8",
    "@types/bun": "1.3.14",
    "@types/node": "^26.0.0",
    "lefthook": "^2.1.9",
    "nuxt": "4.4.8",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "typescript": "6"
  }
}
