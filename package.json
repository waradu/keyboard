{
  "name": "@waradu/keyboard",
  "version": "9.0.0",
  "description": "A keyboard manager compatible with JavaScript, TypeScript and Nuxt",
  "keywords": [
    "events",
    "hotkeys",
    "keybinds",
    "keyboard",
    "nuxt",
    "shortcuts"
  ],
  "homepage": "https://waradu.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/waradu/keyboard.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./nuxt": {
      "types": "./dist/nuxt/index.d.mts",
      "import": "./dist/nuxt/index.mjs"
    }
  },
  "scripts": {
    "build": "unbuild",
    "prepack": "bun run build",
    "playground": "cd playground && bun dev",
    "playground:prepare": "cd playground && bun i",
    "setup": "lefthook install",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix --fix-suggestions",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@nuxt/kit": "4.4.8"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.3",
    "@nuxt/schema": "4.4.8",
    "@types/bun": "1.3.14",
    "@types/node": "^26.0.0",
    "lefthook": "^2.1.9",
    "nuxt": "4.4.8",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "6.0.3",
    "unbuild": "^3.0.0"
  }
}
